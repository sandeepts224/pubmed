  "warnings_and_precautions": [
    {
      "section": "5.1",
      "title": "Severe and Fatal Immune-Mediated Adverse Reactions",
      "summary": "Can occur in any organ system or tissue, can affect more than one body system simultaneously, can occur at any time after starting treatment or after discontinuation"
    },
    {
      "section": "5.2",
      "title": "Infusion-Related Reactions",
      "summary": "Interrupt, slow rate, or permanently discontinue based on severity"
    },
    {
      "section": "5.3",
      "title": "Complications of Allogeneic HSCT",
      "summary": "Fatal and serious complications in patients receiving allo-HSCT before or after PD-1/PD-L1 blocking antibody"
    },
    {
      "section": "5.4",
      "title": "Increased Mortality in Multiple Myeloma",
      "summary": "Not recommended with thalidomide analogue plus dexamethasone outside clinical trials"
    },
    {
      "section": "5.5",
      "title": "Embryo-Fetal Toxicity",
      "summary": "Can cause fetal harm"
    }
  ],
